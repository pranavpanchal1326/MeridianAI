# ─────────────────────────────────────────────
# UnwindAI v2.0 — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local — it is in .gitignore
# ─────────────────────────────────────────────

# AI — Anthropic
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Database — Supabase
# Get from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Queue + Rate Limiting — Upstash Redis
# Get from: https://console.upstash.com
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Blockchain — Polygon Amoy Testnet
# RPC URL from Alchemy or QuickNode
POLYGON_RPC_URL=
# Deployer wallet private key — NEVER the user's MetaMask key
WALLET_PRIVATE_KEY=

# IPFS — Web3.Storage
# Get from: https://web3.storage → Account → API Tokens
WEB3_STORAGE_TOKEN=

# Communications — Twilio
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Wallet Connect — for MetaMask + WalletConnect modal
# Get from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Smart Contract Addresses — filled after deploy (Phase 7.2)
NEXT_PUBLIC_TRUSTVAULT_ADDRESS=
NEXT_PUBLIC_PROOF_TIMELINE_ADDRESS=
NEXT_PUBLIC_ESCROW_ADDRESS=

# Demo Mode
# Set to true before any live demo presentation
# When true: ALL AI and ML routes return cached responses instantly
# When true: zero Anthropic API calls, zero ONNX inference
# When false: full live system
DEMO_MODE=false